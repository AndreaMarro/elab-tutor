{
  "$schema": "https://elabtutor.school/schema/openclaw-l2-template-v1.json",
  "id": "L2-explain-pwm-fade",
  "version": "1.0.0",
  "level": "L2",
  "name": "explainPwmFade",
  "description": "Morphic template: spiegazione PWM + analogWrite via analogia rubinetto rapido aperto/chiuso (Vol.1 cap.6 / Vol.2 cap.8 LED fade). Highlight pin PWM (D3,D5,D6,D9,D10,D11) sul Nano, esempio fade 0-255, citazione VERBATIM, voice TTS Isabella.",
  "category": "lesson-explain",
  "owner_agent": "toolspec-expand-opus",
  "iter_introduced": 14,
  "principio_zero": {
    "plurale_obbligatorio": "Ragazzi,",
    "citazione_verbatim": true,
    "max_parole": 60,
    "max_frasi": 3,
    "vol_pag": "Vol.2 pag.78",
    "analogia": "rubinetto rapido aperto/chiuso = LED che lampeggia velocissimo sembra dimmer"
  },
  "morfismo_sense_1_5": {
    "docente_esperienza": ["primo-anno", "esperto"],
    "classe_eta": ["secondaria-1-2", "secondaria-3"],
    "kit_tier": ["basic", "advanced"],
    "lim_distance_m": 5,
    "adapt_voice": true,
    "adapt_complexity_lessico": true
  },
  "inputs": {
    "experimentId": { "type": "string", "required": false, "default": "v2-cap8-esp1" },
    "pwmPin": { "type": "string", "required": false, "default": "D9" },
    "fadeRange": { "type": "string", "required": false, "default": "0-255" },
    "kitTier": { "type": "string", "enum": ["basic", "advanced"], "default": "basic" },
    "docenteExperienceLevel": { "type": "string", "enum": ["primo-anno", "esperto"], "default": "esperto" }
  },
  "sequence": [
    {
      "step": "highlight-pwm-pins",
      "tool": "highlightPin",
      "args": { "ids": ["nano:D3", "nano:D5", "nano:D6", "nano:D9", "nano:D10", "nano:D11"], "color": "orange", "duration_ms": 4000 },
      "expected_status": "ok"
    },
    {
      "step": "ask-unlim-pwm-context",
      "tool": "askUNLIM",
      "args": { "query": "spiegazione PWM analogWrite duty cycle 0-255 LED fade rubinetto rapido", "context": "explain-pwm-fade" },
      "expected_status": "ok"
    },
    {
      "step": "show-nudge-pwm-pins",
      "tool": "showNudge",
      "args": { "text": "Solo i pin con tilde (~) supportano PWM: D3, D5, D6, D9, D10, D11. Sul Nano cercate il simbolo.", "type": "info", "duration_ms": 6000 },
      "expected_status": "ok"
    },
    {
      "step": "capture-screenshot-fade-circuit",
      "tool": "captureScreenshot",
      "args": { "target": "led-pwm-circuit", "annotate": true },
      "expected_status": "ok"
    },
    {
      "step": "speak-explain-pwm",
      "tool": "speakTTS",
      "args": {
        "text": "Ragazzi, Vol.2 pag.78: PWM apre e chiude rapido come un rubinetto. analogWrite va da 0 a 255: il LED sembra cambiare luminosità ma in realtà lampeggia.",
        "voice": "it-IT-IsabellaNeural",
        "speed": 0.95
      },
      "expected_status": "ok"
    }
  ],
  "fallback_strategy": "halt-on-error",
  "expected_outcome": "Classe identifica pin PWM con tilde sul Nano, comprende analogWrite 0-255, vede LED dimmer in azione",
  "expected_total_latency_ms": 5200,
  "telemetry": {
    "category": "lesson-explain",
    "expected_latency_ms": 5200
  },
  "test_assertions": [
    "sequence.length === 5",
    "sequence[0].tool === 'highlightPin'",
    "sequence[4].args.text.includes('Ragazzi,')",
    "sequence[4].args.text.match(/Vol\\.\\d/)",
    "principio_zero.max_parole <= 60",
    "principio_zero.analogia.includes('rubinetto')"
  ]
}
