# ELAB Builder — Required Environment Variables
# Copy to .env and fill in values
# All VITE_ prefixed vars are exposed to the client bundle by Vite.

# Galileo Chat AI webhook (n8n)
VITE_N8N_CHAT_URL=

# Admin CRUD webhook (n8n → Notion)
VITE_ADMIN_WEBHOOK=

# License verification webhook (n8n → Notion)
VITE_N8N_LICENSE_URL=

# Analytics webhook (n8n — simulator lifecycle events)
VITE_ANALYTICS_WEBHOOK=https://andreamarro.app.n8n.cloud/webhook/elab-simulator-analytics

# Optional: Nanobot server (priority over n8n for text chat)
# VITE_NANOBOT_URL=http://localhost:8100

# Optional: standalone compile server URL
# VITE_COMPILE_URL=

# Optional: n8n compile webhook fallback
# VITE_N8N_COMPILE_URL=

# Optional: local dev API
# VITE_LOCAL_API_URL=
# VITE_LOCAL_COMPILE_URL=

# Optional: API timeout in ms (default: 30000)
# VITE_API_TIMEOUT=30000

# Data Server (backend EU per sync studenti + Teacher Dashboard)
# VITE_DATA_SERVER_URL=https://elab-data.onrender.com

# Auth Server URL (Netlify Functions)
# VITE_AUTH_URL=

# Optional: HMAC session secret (auto-generated per session if not set)
# VITE_SESSION_SECRET=
