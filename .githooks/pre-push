#!/bin/bash
# ELAB pre-push hook — anti-regression completo su main
# Install: git config core.hooksPath .githooks

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Non-main branch → quick check only
if [ "$BRANCH" != "main" ]; then
  echo "[pre-push] Branch '$BRANCH' (non main) — quick regression check"
  SCRIPT="$(git rev-parse --show-toplevel)/scripts/quick-regression-check.sh"
  if [ -f "$SCRIPT" ]; then
    "$SCRIPT" || exit $?
  fi
  exit 0
fi

# Bypass esplicito documentato
if [ "$ELAB_SKIP_PREPUSH" = "1" ]; then
  echo "[pre-push] ELAB_SKIP_PREPUSH=1 — skipping (ON YOUR OWN RISK)"
  exit 0
fi

echo ""
echo "════════════════════════════════════════════"
echo "  ELAB ANTI-REGRESSION GATE — push su main"
echo "════════════════════════════════════════════"

FULL_GATE="$(git rev-parse --show-toplevel)/scripts/anti-regression-gate.sh"
if [ ! -f "$FULL_GATE" ]; then
  echo "[pre-push] FATAL: anti-regression-gate.sh non trovato"
  exit 1
fi

"$FULL_GATE"
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo "████████████████████████████████████████████"
  echo "  PUSH BLOCCATO — regressione rilevata"
  echo "████████████████████████████████████████████"
  echo ""
  echo "Azioni:"
  echo "  1. Leggi automa/state/gate-result.json per dettagli"
  echo "  2. 'git stash' se vuoi isolare le modifiche"
  echo "  3. Fix + ripeti"
  echo "  4. Bypass SOLO con ragione scritta: ELAB_SKIP_PREPUSH=1 git push"
  echo ""
  exit 1
fi

echo ""
echo "✓ Quality gate passato — push consentito"
echo ""
exit 0
