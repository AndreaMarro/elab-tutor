# ============================================
# ELAB Tutor — .gitignore
# ============================================

# Dependencies
node_modules/

# Build output
dist/
build/

# Dataset output and large training files (regenerable via brain factory)
datasets/output/
datasets/*.jsonl
datasets/v13-combined/
datasets/batches/
datasets/curriculum/*.jsonl
datasets/curriculum-v11/
datasets/sprint-v12/*.jsonl
datasets/sprint-finale/*.jsonl

# AI model files (2.3 GB+)
models/*.gguf
models/*.safetensors
models/*.bin
models/*.pt
models/*.pth

# Runtime state (must NOT be reverted by git checkout -- .)
automa/state/last-eval.json
automa/state/cycle-snapshot.json

# Environment files
.env
.env.local
.env.*.local
.env.vercel-check

# Vercel
.vercel/

# Test coverage (regenerable)
coverage/

# OS files
.DS_Store
Thumbs.db

# Python cache (nanobot)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Nanobot runtime sessions
nanobot/sessions/memory/
nanobot/sessions/site/
nanobot/sessions/tutor/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Serena tool cache
.serena/cache/

# Playwright
test-results/
playwright-report/
tests/e2e/results/

# Logs
*.log
npm-debug.log*

# Temporary files
*.tmp
*.temp
.env*.local
datasets/galileo-brain-20k.jsonl
# Claude Code (personal per ogni developer)
.claude/*
# Ma gli agenti della Triade sono asset del progetto, non config personale
!.claude/agents/

# Audit screenshots and reports (generated, not source)
audit-*.png
audit-*.json
audit-*.mjs
audit-*.js
screenshot-*.png
console-errors*.png
homepage_*.png
2026-*.png

# Bench output (regenerable, large, not source — iter 39 carryover housekeeping)
scripts/bench/output/
.vercel/env.prod

# External agents repo (cloned locally, non committare il mass)
.claude/external-agents/wshobson-agents/

# caveman + caveman-compression (clone locali)
.claude/external-agents/caveman/
.claude/external-agents/caveman-compression/
.claude/external-agents/oh-my-claudecode/

# agency-agents (226 md files, local only)
.claude/external-agents/agency-agents/

# === Ephemeral state files (added 2026-05-03 iter34 step 2 cleanup) ===
# heartbeat — written by launchctl com.elab.automa.watchdog (local) every ~minute
automa/state/heartbeat
# iter-19-harness-2.0-results.json — bench harness cron rewrites timestamp + minor description_len shifts
automa/state/iter-19-harness-2.0-results.json
# sprint-r0-score-results.json — bench score cron output (re-run by sprint-r0 workload)
scripts/bench/workloads/sprint-r0-score-results.json

# Playwright report output ephemeral (added 2026-05-03 iter 34 step 3)
automa/state/iter-31-l0b-namespace-50-cells/
